@using AmidPortfolio.Services
@using MudBlazor
@inject ThemeService ThemeService
@inject IJSRuntime JS
@implements IDisposable
@inject NavigationManager Navigation

<MudBreakpointProvider OnBreakpointChanged="BreakpointChanged" />
<MudAppBar Elevation="0" Class="custom-appbar">

        <MudContainer MaxWidth="MaxWidth.ExtraLarge"> 

   <div class="appbar-content">

            <MudText Class=@($"logo-text fw-bold") style="@($"--logo-text-bg:{GradientService.CurrentTheme.Background}")" Typo="Typo.h6" @onclick="ReloadPage">
            Amid Gigante Jr.
        </MudText>

       @*  <MudSpacer/> *@

        <!-- Desktop View -->
        <MudHidden Breakpoint="Breakpoint.MdAndDown">
            <div class="nav-links" style="@($"--menu-color:{GradientService.CurrentTheme.Color}")">
                    @foreach (var item in MenuItems)
                    {
                        <MudButton Class="@GetClass(item.Id)"
                                   OnClick="@(() => Go(item.Id))">
                            @item.Text
                        </MudButton>
                    }

                @*   <MudIconButton Icon="@(ThemeService.IsDarkMode
                                                      ? Icons.Material.Filled.LightMode
                                              : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="ToggleTheme" /> *@
            </div>
        </MudHidden>

        <!-- Mobile View -->
        <MudHidden Breakpoint="Breakpoint.LgAndUp">

                @if(!_showMenu)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" class="animate__animated animate__fadeIn"
                                   Color="Color.Inherit"
                                   OnClick="ToggleMenu" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Close" class="animate__animated animate__fadeIn"
                                   Color="Color.Inherit"
                                   OnClick="ToggleMenu" />
                }


        </MudHidden>


    </div> 

        </MudContainer>
 
</MudAppBar>

@if (_showMenu)
{
    <div class="mobile-menu @(_showMenu ? "show" : "")" style="@($"--menu-color:{GradientService.CurrentTheme.Color}")">
        @foreach (var item in MenuItems)
        {
            <MudButton FullWidth="true"
                       Class="@GetClass(item.Id)"
                       OnClick="@(() => Go(item.Id))">
                @item.Text
            </MudButton>
        }

       @*  <MudNavMenu Dense="true">
            <MudNavLink Class="active-nav" Href="#stack">Home</MudNavLink>
            <MudNavLink Href="#stack">About</MudNavLink>

            <MudNavLink Href="#projects">Portfolio</MudNavLink>

            <MudNavLink Href="#contact">Contact</MudNavLink>

        </MudNavMenu> *@

    </div>
}

<style>
    .custom-appbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(5, 8, 22, 0.45) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,.06);
        z-index: 9999;
    }

        .custom-appbar::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient( 90deg, rgba(139,92,246,.05), rgba(59,130,246,.05) );
            pointer-events: none;
        }

    .appbar-content {
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }


    .logo-text {
        background-image: var(--logo-text-bg);
        font-weight: bold;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        cursor: pointer;
    }

    /**/
    .nav-links {
        display: flex;
        gap: 1rem;
    }

    .active-nav {
        position: relative;
        color: var(--menu-color) !important;
    }

        .active-nav::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -4px;
            width: 100%;
            height: 2px;
            background: var(--menu-color);
        }

    /* Mobile view*/
    .mobile-menu {
        position: fixed;
        top: 64px; /* height of AppBar */
        left: 0;
        right: 0;
        margin: 16px;
        border-radius: 20px;
        background: rgba(5, 8, 22, 0.45) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 1300;
        padding: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,.35);
        transform: translateY(-20px);
        transition: .3s;
        opacity: 0;
    }

        .mobile-menu.show {
            transform: translateY(0);
            opacity: 1;
        }

    .mobile-home{
        color:red;
    }
</style>
@code {
    [Parameter] public EventCallback OnToggleTheme { get; set; }

    private bool _isMobile;

    private readonly List<(string Id, string Text)> MenuItems =
    [
        ("home", "Home"),
        ("about", "About"),
        ("portfolio", "Portfolio"),
        ("contact", "Contact")
    ];

    private bool _showMenu;
    private void ToggleTheme()
    {
        ThemeService.ToggleTheme();
    }

    protected override void OnInitialized()
    {
        NavigationService.OnSectionChanged += HandleSectionChanged;
        GradientService.OnChange += Refresh;
    }

    private async Task Go(string id)
    {
        await NavigationService.ScrollTo(id);
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetClass(string section)
    {
        return NavigationService.ActiveSection == section
            ? "active-nav"
            : "";
    }


    void ToggleMenu()
    {
        _showMenu = !_showMenu;
    }

    private void HandleSectionChanged(string section)
    {
        InvokeAsync(StateHasChanged);
    }

    private Task BreakpointChanged(Breakpoint breakpoint)
    {
        _isMobile = breakpoint <= Breakpoint.Sm;

        if (!_isMobile && _showMenu)
            _showMenu = false;

        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ReloadPage()
    {
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    public void Dispose()
    {
        NavigationService.OnSectionChanged -= HandleSectionChanged;
        GradientService.OnChange -= Refresh;
    }

}