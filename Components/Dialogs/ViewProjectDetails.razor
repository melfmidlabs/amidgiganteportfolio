        font-size:.875rem;
    }

        .nav-buttons {
            display: flex;
            gap: .5rem;
            margin-right: 10px;
        }
}
</style>
@code {
    [Parameter]
    public EventCallback OnClose { get; set; }
    [Parameter]
    public int ProjectId { get; set; }

    private List<ProjectModel> Projects = new();

    private ProjectModel? CurrentProject;

    private int selectedProject = 0;
    private int selectedImage = 0;

    private bool _showImageOverlay;
    private string? _selectedImage;

    private string GetThumbClass(int index)
        => selectedImage == index
            ? "thumb active"
            : "thumb";

    private string CurrentImage =>
      CurrentProject?.Images[selectedImage] ?? "";

    protected override void OnInitialized()
    {
        GradientService.OnChange += Refresh;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadProject();
    }

    private async Task LoadProject()
    {

        if (!Projects.Any())
        {

            Projects = await Http.GetFromJsonAsync<List<ProjectModel>>("data/projects.json") ?? new();
        }

        CurrentProject = Projects.FirstOrDefault(p => p.Id == ProjectId);        
    }


    private void NextImage()
    {
        if (CurrentProject == null)
            return;

        selectedImage++;

        if (selectedImage >= CurrentProject.Images.Count)
            selectedImage = 0;
    }

    private void PreviousImage()
    {
        if (CurrentProject == null)
            return;

        selectedImage--;

        if (selectedImage < 0)
            selectedImage = CurrentProject.Images.Count - 1;
    }

    private void SelectImage(int index)
    {
        selectedImage = index;
    }

    private void SelectProject(int index)
    {
        selectedProject = index;
        CurrentProject = Projects[index];

        // Reset to the first image of the newly selected project
        selectedImage = 0;
    }

    private void OpenImage(string image)
    {
        _selectedImage = image;
        _showImageOverlay = true;
    }

    private void CloseImage()
    {
        _showImageOverlay = false;
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }



    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }


    public void Dispose()
    {
        GradientService.OnChange -= Refresh;
    }

    private async Task PreviousProject()
    {
        if (ProjectId == 1) return;

        ProjectId--;
        selectedImage = 0;
        await LoadProject();
        //StateHasChanged();
    }
    private async Task NextProject()
    {
        if (ProjectId == Projects.Count)
            return;

        ProjectId++;
        selectedImage = 0;
        await LoadProject();
        //StateHasChanged();
    }
}
