@implements IDisposable


<!--First Section-->
<MudGrid Class="tech-grid-container" style="@($"--color-rgba:{GradientService.CurrentTheme.ShadowRgba};--color-shadow:{GradientService.CurrentTheme.Shadow}")">
    <!--Frontend-->
    <MudItem xs="12" md="4">
        <MudPaper Class="tech-section" >

            <div class="tech-header" >

                <div class="title-wrapper">

                    <MudIcon Icon="@Icons.Material.Rounded.DesktopWindows"
                             Class="section-icon" style="@($"color:{Colors.Purple.Default};")" />

                    <div>

                        <MudText Typo="Typo.h4"
                                 Class="fw-bold techstack-title">
                            Frontend
                        </MudText>

                        <div class="title-line"></div>

                    </div>

                </div>

                <div class="dots">
                    @for (int i = 0; i < 16; i++)
                    {
                        <span></span>
                    }
                </div>

            </div>

            <MudText Class="section-description mt-6 mb-8">
                Technologies I use to build interactive and responsive user interfaces.
            </MudText>

            <div class="tech-grid">

                @foreach (var tech in Frontend)
                {

          
                    <MudPaper Class="tech-card">

                      @*   <i class="@tech.Icon tech-icon"
                           style="color:@tech.Color">
                        </i> *@
                        <img src="@tech.Icon"
                         alt="@tech.Name"
                         class="tech-icon" />

                        <MudText Typo="Typo.subtitle1"
                                 Class="mt-4 tech-name fw-bold">
                            @tech.Name
                        </MudText>

                    </MudPaper>

         
                }

            </div>

        </MudPaper>
    </MudItem>
   
    <!--Backend-->
    <MudItem xs="12" md="4">
        <MudPaper Class="tech-section pa-8">

            <div class="tech-header">

                <div class="title-wrapper">

                    <MudIcon Icon="@Icons.Material.Rounded.DesktopWindows"
                             Class="section-icon" style="@($"color:{Colors.Blue.Darken2};")" />

                    <div>

                        <MudText Typo="Typo.h4"
                                 Class="fw-bold techstack-title">
                            Backend
                        </MudText>

                        <div class="title-line"></div>

                    </div>

                </div>

                <div class="dots">
                    @for (int i = 0; i < 16; i++)
                    {
                        <span></span>
                    }
                </div>

            </div>

            <MudText Class="section-description mt-6 mb-8">
                Technologies I use to build robust APIs and server-side applications
            </MudText>

            <div class="tech-grid">

                @foreach (var tech in Backend)
                {

          
                    <MudPaper Class="tech-card">

                       <img src="@tech.Icon"
                         alt="@tech.Name"
                         class="tech-icon" />

                        <MudText Typo="Typo.subtitle1"
                                 Class="mt-4 tech-name fw-bold">
                            @tech.Name
                        </MudText>

                    </MudPaper>

         
                }

            </div>

        </MudPaper>
    </MudItem>
   
    <!--Database-->
    <MudItem xs="12" md="4">
        <MudPaper Class="tech-section pa-8">

            <div class="tech-header">

                <div class="title-wrapper">

                    <MudIcon Icon="@Icons.Material.Rounded.Api"
                             Class="section-icon" style="@($"color:{Colors.DeepPurple.Default};")" />

                    <div>

                        <MudText Typo="Typo.h4"
                                 Class="fw-bold techstack-title">
                            Database
                        </MudText>

                        <div class="title-line"></div>

                    </div>

                </div>

                <div class="dots">
                    @for (int i = 0; i < 16; i++)
                    {
                        <span></span>
                    }
                </div>

            </div>

            <MudText Class="section-description mt-6 mb-8">
                Technologies I use to build robust APIs and server-side applications
            </MudText>

            <div class="tech-grid">

                @foreach (var tech in Database)
                {

          
                    <MudPaper Class="tech-card">

                       <img src="@tech.Icon"
                         alt="@tech.Name"
                         class="tech-icon" />

                        <MudText Typo="Typo.subtitle1"
                                 Class="mt-4 tech-name fw-bold">
                            @tech.Name
                        </MudText>

                    </MudPaper>

         
                }

            </div>

        </MudPaper>
    </MudItem>
</MudGrid>


