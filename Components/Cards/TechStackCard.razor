<style>

    .tech-grid-container {
    align-items: stretch;
}

.tech-grid-container .mud-grid-item {
    display: flex;
}

    .techstack-title{
        font-size: 24px;
    }

    .tech-section {
        padding:24px;
        position: relative;
        overflow: hidden;
        border-radius: 22px;
        background: rgba(17, 24, 39, 0.50);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,.10);
        display: flex;
        flex-direction: column;
        width: 100%;
        height: 100%;
    }

        .tech-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, var(--color-rgba), transparent 35%);
            pointer-events: none;
        }

    .tech-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .title-wrapper {
        display: flex;
        align-items: flex-start;
        gap: 18px;
    }

    .section-icon {
        font-size: 42px;
        /* color: #a855f7; */
    }

 

    .title-line {
        width: 60px;
        height: 4px;
        border-radius: 30px;
        background: #a855f7;
        margin-top: 8px;
    }

    .section-description {
        color: #9ca3af;
        max-width: 420px;
        line-height: 1.8;
    }

    .tech-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: calc(.25rem * 2);
    }

    .tech-card {
        max-height: 170px;
        padding:8px;
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: .75rem;
        background: rgba(255,255,255,.02);
       /*  border: 1px solid rgba(168,85,247,.35); */
        border: 1px solid var(--color-rgba);
        transition: .35s ease;
        position: relative;
        overflow: hidden;
    }

        .tech-card::before {
            content: "";
            position: absolute;
            inset: 0;
        /*     background: linear-gradient( 180deg, rgba(168,85,247,.10), transparent); */
            background: linear-gradient( 180deg, var(--color-rgba), transparent);
            opacity: 0;
            transition: .35s;
        }

   /*  .tech-icon {
        font-size: 32px;
        transition: .35s;
    } */
    .tech-icon {
        width: 32px;
        height: 32px;
        object-fit: contain;
        transition: .35s;
    }

    .tech-name{
        font-size:10px;
        
    }

    .tech-card:hover {
        transform: translateY(-10px) scale(1.04);
      /*   border-color: #a855f7; */
        border-color: var(--color-shadow);
        box-shadow: 0 0 25px rgba(168,85,247,.25), inset 0 0 30px rgba(168,85,247,.08);
    }

        .tech-card:hover::before {
            opacity: 1;
        }

        .tech-card:hover .tech-icon {
            transform: translateY(-4px) scale(1.15) rotate(-5deg);
        }

        .tech-card:hover .mud-typography {
            color: #fff;
        }

    .dots {
        width: 70px;
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 8px;
    }

        .dots span {
            width: 4px;
            height: 4px;
            background: #6d28d9;
            border-radius: 50%;
            opacity: .6;
        }

    @@media (max-width: 1200px) {
        .tech-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @@media (max-width: 900px) {
        .tech-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 600px) {
        .tech-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 400px) {
        .tech-grid {
            grid-template-columns: 1fr;
        }
    }

</style>
