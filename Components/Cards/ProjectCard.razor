@using AmidPortfolio.Models
@implements IDisposable

<MudOverlay Visible="@showVideo" Style="backdrop-filter: blur(10px); z-index:9999;background-color: rgba(0, 0, 0, 0.9);"
            DarkBackground="true"
            AutoClose="false" >

    <div class="video-viewer">

        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Class="video-close-btn"
                       OnClick="@(() => showVideo = false)" />

        <video controls
               autoplay
               class="demo-video">

            <source src="@SelectedVideoUrl"
                    type="video/mp4">

        </video>

    </div>

</MudOverlay>

<MudGrid Class="">

    @for (int count = 0; count < ProjectsModel.Count; count++)
    {
        var project = ProjectsModel[count];

        if(count == 0)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper @onclick="@(() => Snackbar.Add("Under development. Feature will add soon.", Severity.Info))"
                    Class="project-card-portfolio" style="@($"--project-card-portfolio-shadow:{GradientService.CurrentTheme.ShadowRgba}; --project-card-portfolio-color:{GradientService.CurrentTheme.Color}")"
                          data-aos="fade-up-right"
                          data-aos-duration="1000">

                    <div class="stats-gradient"></div>

                    <div class="project-image-container">

                        <MudPaper Class="project-badge" Elevation="0">

                            <MudText Class="project-badge-text">
                                02
                            </MudText>
                        </MudPaper>

                        <MudPaper Class="project-arrow" Elevation="0">

                            <MudIcon Icon="@Icons.Material.Rounded.ArrowOutward"
                                     Class="project-arrow-icon" />

                        </MudPaper>
                        <MudImage Src="@project.ImageUrl"
                                  Alt="@project.Title"
                                  Class="project-image" />

                    </div>

                    <div class="project-content">

                        <MudText Typo="Typo.h5"
                                 Class="project-title-gradient">
                            @project.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="project-description">
                            @project.Description
                        </MudText>

                        <MudDivider class="mb-4"/>

                        <MudStack Row
                                  Wrap="Wrap.Wrap"
                                  Spacing="1">

                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">
                                <i class="devicon-csharp-plain colored me-2" ></i>
                                C#

                            </MudChip>

                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">
                                <i class="devicon-blazor-original colored me-2" ></i>
                                Blazor
                            </MudChip>

                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">
                                <MudIcon Icon="@Icons.Custom.Brands.MudBlazor" Color="Color.Primary"
                                         Class="me-2" />
                                MudBlazor
                            </MudChip>

                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">
                                <i class="devicon-postgresql-plain colored me-2"></i>
                                PostgreSQL
                            </MudChip>
                        </MudStack>
                        @* <div class="project-footer">

