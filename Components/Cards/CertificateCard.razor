    private void OpenCertificate(string imageUrl)
    {
        SelectedCertificate = imageUrl;
        visible = true;
    }

      protected override void OnInitialized()
    {
        GradientService.OnChange += Refresh;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GradientService.OnChange -= Refresh;
    }

