@implements IDisposable

<MudOverlay Visible="visible" Style="backdrop-filter: blur(10px); z-index:9999;"
            DarkBackground="true"
            AutoClose="false"
            OnClosed="@(() => visible = false)" data-aos="fade-up"
                          data-aos-duration="600">

    <div class="certificate-viewer">

        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Class="certificate-close-btn"
                       Color="Color.Default"
                       OnClick="@(() => visible = false)" />

        <img src="@SelectedCertificate"
             alt="Certificate"
             class="certificate-preview-image" />

    </div>

</MudOverlay>

<MudGrid Class="px-4" style="@($"--color-rgba:{GradientService.CurrentTheme.ShadowRgba};--color-shadow:{GradientService.CurrentTheme.Shadow}")">

    @for (int count = 0; count < CertificatesModel.Count; count++)
    {
        var certificate = CertificatesModel[count];
        if (count == 0)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="certificate-card" data-aos="fade-up-right"
                          data-aos-duration="1000" @onclick="() => OpenCertificate(certificate.ImageUrl)">
               
                    <div class="certificate-image-container">

                        <MudImage Src="@certificate.ImageUrl"
                                  Alt="programmer of the year"
                                  Class="certificate-image" />

                        <div class="certificate-overlay-badge">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium"
                                     Class="certificate-badge" />
                        </div>

                        <div class="certificate-overlay">

                            <div class="view-certificate">

                                <MudIcon Icon="@Icons.Material.Filled.ZoomIn"
                                         Size="Size.Large" />

                                <MudText Typo="Typo.h6" Class="view-certificate-text">
                                    View Certificate
                                </MudText>

                            </div>

                        </div>

                    </div>

                    <div class="certificate-content">

                        <MudText Typo="Typo.h5"
                                 Class="certificate-title-gradient">
                            @certificate.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-issuer">
                            @certificate.Issuer
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-date">
                            @certificate.IssuedDate
                        </MudText>

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.body2"
                                 Class="certificate-description">
                            @certificate.Description
                        </MudText>

                       @*  <div class="certificate-footer">

                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       EndIcon="@Icons.Material.Filled.Visibility"
                                       Class="certificate-button px-6">

                                View Certificate

                            </MudButton>

                        </div> *@

                    </div>

                </MudPaper>
            </MudItem>
        }
        else if (count == 1)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="certificate-card" data-aos="fade-up"
                          data-aos-duration="1200" @onclick="() => OpenCertificate(certificate.ImageUrl)">

                    <div class="certificate-image-container">

                        <MudImage Src="@certificate.ImageUrl"
                                  Alt="programmer of the year"
                                  Class="certificate-image" />

                        <div class="certificate-overlay-badge">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium"
                                     Class="certificate-badge" />
                        </div>

                        <div class="certificate-overlay">

                            <div class="view-certificate">

                                <MudIcon Icon="@Icons.Material.Filled.ZoomIn"
                                         Size="Size.Large" />

                                <MudText Typo="Typo.h5">
                                    View Certificate
                                </MudText>

                            </div>

                        </div>

                    </div>

                    <div class="certificate-content">

                        <MudText Typo="Typo.h5"
                                 Class="certificate-title-gradient">
                            @certificate.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-issuer">
                            @certificate.Issuer
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-date">
                            @certificate.IssuedDate
                        </MudText>

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.body2"
                                 Class="certificate-description">
                            @certificate.Description
                        </MudText>

                      @*   <div class="certificate-footer">

                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       EndIcon="@Icons.Material.Filled.Visibility"
                                       Class="certificate-button px-2">

                                View Certificate

                            </MudButton>

                        </div> *@

                    </div>

                </MudPaper>
            </MudItem>
        }
        else if (count == 2)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="certificate-card" data-aos="fade-up-left"
                          data-aos-duration="1000" @onclick="() => OpenCertificate(certificate.ImageUrl)">

                    <div class="certificate-image-container">

                        <MudImage Src="@certificate.ImageUrl"
                                  Alt="programmer of the year"
                                  Class="certificate-image" />

                        <div class="certificate-overlay-badge">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium"
                                     Class="certificate-badge" />
                        </div>

                        <div class="certificate-overlay">

                            <div class="view-certificate">

                                <MudIcon Icon="@Icons.Material.Filled.ZoomIn"
                                         Size="Size.Large" />

                                <MudText Typo="Typo.h5">
                                    View Certificate
                                </MudText>

                            </div>

                        </div>

                    </div>

                    <div class="certificate-content">

                        <MudText Typo="Typo.h5"
                                 Class="certificate-title-gradient">
                            @certificate.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-issuer">
                            @certificate.Issuer
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="certificate-date">
                            @certificate.IssuedDate
                        </MudText>

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.body2"
                                 Class="certificate-description">
                            @certificate.Description
                        </MudText>

                     @*    <div class="certificate-footer">

                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       EndIcon="@Icons.Material.Filled.Visibility"
                                       Class="certificate-button px-2">

                                View Certificate

                            </MudButton>

                        </div> *@

                    </div>

                </MudPaper>
            </MudItem>
        }

    }

</MudGrid>

<style>
  /*   .certificate-card {
        background: linear-gradient( 135deg, rgba(30,41,59,.95), rgba(49,46,129,.65) );
        border: 1px solid rgba(255,255,255,.08);
        border-radius: .75rem;
        overflow: hidden;
        height: 100%;
        transition: all .35s ease;
        backdrop-filter: blur(16px);
    } */
    .certificate-card {
       /*  background: linear-gradient( 135deg, rgba(30,41,59,.95), rgba(49,46,129,.60) );
        border: 1px solid rgba(255,255,255,.08); */
        background: rgba(17, 24, 39, 0.50);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,.10);
        border-radius: .75rem;
        overflow: hidden;
        height: 100%;
        backdrop-filter: blur(16px);
        transition: all .35s ease;
        cursor: pointer;
    }

        .certificate-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px var(--color-rgba);
        }

    .certificate-image-container {
        position: relative;
        padding: 20px 20px 0 20px;
    }

    .certificate-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: .5rem;
        transition: all .4s ease;
    }

    .certificate-card:hover .certificate-image {
        transform: scale(1.03);
    }

    .certificate-overlay-badge {
        position: absolute;
        top: 32px;
        right: 32px;
    }

    /**/
    /* Hidden by default */
    .certificate-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, .65);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity .3s ease;
    }

    /* Show only on hover */
    .certificate-card:hover .certificate-overlay {
        opacity: 1;
    }

    /* Slight zoom effect */
    .certificate-card:hover .certificate-image {
        transform: scale(1.03);
    }

    .view-certificate {
        color: white;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        transform: translateY(10px);
        transition: all .3s ease;
    }

    .view-certificate-text{
        margin: 0px;
        font-family: Roboto, Helvetica, Arial, sans-serif;
        font-size: 1.25rem;
        line-height: 1.6;
        letter-spacing: 0.0075em;
        font-weight: 600;
        text-shadow: rgba(0, 0, 0, 0.3) 0px 2px 4px;
    }

    .certificate-card:hover .view-certificate {
        transform: translateY(0);
    }

    /**/

    .certificate-badge {
        color: gold;
        font-size: 2rem;
        filter: drop-shadow( 0 0 10px rgba(255,215,0,.4) );
    }

    .certificate-content {
        padding: 24px;
    }


    .certificate-title-gradient {
        font-weight: 600;
        background: linear-gradient( 90deg, #bfdbfe, #d8b4fe, #fbcfe8 );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .certificate-issuer {
        color: #a78bfa;
        margin-top: 8px;
    }

    .certificate-date {
        color: rgba(255,255,255,.60);
    }

    .certificate-description {
        color: rgba(255,255,255,.75);
        line-height: 1.7;
    }


    .certificate-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
    }

    .certificate-button {
        background: rgba(255,255,255,.08);
        border-radius: 10px;
        color: white;
    }

    /**/
    .background-overlay {
        backdrop-filter: blur(10px);
    }

    /**/
    .certificate-viewer {
        position: relative;
        max-width: 1200px;
        width: 90vw;
        margin: auto;
        overflow: hidden;
        border-radius: 16px;
    }

    .certificate-preview-image {
        width: 100%;
        max-height: 85vh;
        object-fit: contain;
        border-radius: 16px;
        transition: all .3s ease;
    }

    /* Darken image on hover */
    .certificate-viewer::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,.15);
        opacity: 0;
        transition: opacity .3s ease;
        border-radius: 16px;
        pointer-events: none;
    }

/*     .certificate-viewer:hover::after {
        opacity: 1;
    }

    .certificate-viewer:hover .certificate-preview-image {
        transform: scale(1.01);
    } */

    .certificate-close-btn {
        position: absolute !important;
        top: 12px;
        right: 70px;
        z-index: 100;
        background: rgba(0,0,0,.55);
        backdrop-filter: blur(8px);
        color: white !important;
        transition: all .3s ease;
    }

        .certificate-close-btn:hover {
            background: rgba(239,68,68,.9);
            transform: rotate(90deg) scale(1.1);
        }
</style>

