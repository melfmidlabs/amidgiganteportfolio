@using AmidPortfolio.Components.Cards
@implements IDisposable

<MudBreakpointProvider OnBreakpointChanged="BreakpointChanged" />
<MudContainer MaxWidth="MaxWidth.ExtraLarge" >
    <MudStack AlignItems="AlignItems.Center">
        <MudStack Class="mb-7" AlignItems="AlignItems.Center" Spacing="1" data-aos="fade-up"
             data-aos-duration="1000">
            <MudText Typo="Typo.h2"
                 Align="Align.Center"
                     Class=@($"gradient-text-title mb-6") style="@($"--gradient-text-title-bg:{GradientService.CurrentTheme.Background}")">
            Portfolio Showcase
            </MudText>

            <MudText Typo="Typo.body1"
                     Align="Align.Center"
                     Class="portfolio-subtitle">
                Explore my journey through projects,
                certifications, technical expertise,
                and professional experience.

            </MudText>
        </MudStack>
        
        @if (_isMobile)
        {
            <MudGrid data-aos="fade-up"
                     data-aos-duration="1200" Class="mb-4" style="@($"--portfolio-tabs-container-bgrgba:{GradientService.CurrentTheme.BackgroundRgba};--portfolio-tabs-container-bg:{GradientService.CurrentTheme.Background};--portfolio-tabs-container-color:{GradientService.CurrentTheme.Color};--portfolio-tabs-container-shadow:{GradientService.CurrentTheme.ShadowRgba}")">

                <MudItem xs="6">
                    <MudButton FullWidth="true" Class="@(activeIndex == 0 ? "mobile-tabs-active" : "mobile-tabs")"
                               OnClick="() => activeIndex = 0">
                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudIcon Icon="@Icons.Material.Outlined.Code" />
                            <MudText>Projects</MudText>
                        </MudStack>
                    </MudButton>
                </MudItem>

                <MudItem xs="6">
                    <MudButton FullWidth="true" 
                               Class="@(activeIndex == 1 ? "mobile-tabs-active" : "mobile-tabs")"
                               OnClick="() => activeIndex = 1">
                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudIcon Icon="@Icons.Material.Outlined.WorkHistory" />
                            <MudText>Experience</MudText>
                        </MudStack>
                    </MudButton>
                </MudItem>

                <MudItem xs="6">
                    <MudButton FullWidth="true"
                               Class="@(activeIndex == 2 ? "mobile-tabs-active" : "mobile-tabs")"
                               OnClick="() => activeIndex = 2">
                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudIcon Icon="@Icons.Material.Outlined.WorkspacePremium" />
                            <MudText>Certificates</MudText>
                        </MudStack>
                    </MudButton>
                </MudItem>

                <MudItem xs="6">
                    <MudButton FullWidth="true"
                               Class="@(activeIndex == 3 ? "mobile-tabs-active" : "mobile-tabs")"
                               OnClick="() => activeIndex = 3">
                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudIcon Icon="@Icons.Material.Outlined.Memory" />
                            <MudText>Tech Stack</MudText>
                        </MudStack>
                    </MudButton>
                </MudItem>

            </MudGrid>
        }
        else
        {
            <MudPaper Class="portfolio-tabs-container mb-4" style="@($"--portfolio-tabs-container-bgrgba:{GradientService.CurrentTheme.BackgroundRgba};--portfolio-tabs-container-bg:{GradientService.CurrentTheme.Background};--portfolio-tabs-container-color:{GradientService.CurrentTheme.Color};--portfolio-tabs-container-shadow:{GradientService.CurrentTheme.ShadowRgba}")">

                <MudTabs Rounded="true"
                         Centered="false"
                         Elevation="0"
                         TabHeaderClass="portfolio-panel"
                         TabPanelsClass="portfolio-tab-panel" @bind-ActivePanelIndex="activeIndex" KeepPanelsAlive="true">

                    <MudTabPanel>

                        <TabContent>
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Outlined.Code" />
                                <MudText>Projects</MudText>
                            </MudStack>
                        </TabContent>

                        @* Projects Content *@

                    </MudTabPanel>

                    <MudTabPanel>

                        <TabContent>
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Outlined.WorkHistory" />
                                <MudText>Experience</MudText>
                            </MudStack>
                        </TabContent>

                        @* Experience Content *@

                    </MudTabPanel>

                    <MudTabPanel>

                        <TabContent>
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Outlined.WorkspacePremium" />
                                <MudText>Certificates</MudText>
                            </MudStack>
                        </TabContent>

                        @* Certificates Content *@

                    </MudTabPanel>

                    <MudTabPanel>

                        <TabContent>
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Outlined.Memory" />
                                <MudText>Tech Stack</MudText>
                            </MudStack>
                        </TabContent>

                        @* Tech Stack Content *@

                    </MudTabPanel>

                </MudTabs>

            </MudPaper>
        }

       

        @if(activeIndex == 0)
        {
            <FeatureProjectCard/>
            <ProjectCard/>
            <MudStack  style="width:100%; margin-top:10px;" AlignItems="AlignItems.Start">
             @*    <MudButton class="ml-2 see-more-button" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.ArrowDownward">
                    <MudText>See More</MudText>
                </MudButton> *@
                <MudButton onclick="@(() => Snackbar.Add("Under development. Feature will add soon.", Severity.Info))"
                           EndIcon="@Icons.Material.Filled.ArrowDownward"
                           Variant="Variant.Outlined"
                           Class="see-more-button ml-3 rounded-lg" Size="Size.Small"
                           Style="@($"--see-more-button-color:{GradientService.CurrentTheme.Color}; --project-button-shadow:{GradientService.CurrentTheme.Shadow};")">

                   See More

                </MudButton>
            </MudStack>
        
        }else if(activeIndex == 1)
        {
           
        }else if(activeIndex == 2)
        {
            <CertificateCard />
        }else if(activeIndex == 3)
        {
            <TechStackCard/>
        }

        <MudDivider class="portfolio-divider"/>
    </MudStack>
</MudContainer>

<style>
    /**/
    .portfolio-divider{
        margin-top:20px;
        margin-bottom:20px;
    }
    /**/
    .portfolio-subtitle {
        max-width: 900px;
        margin: 0 auto;
        font-size: 1rem;
        line-height: 1.5;
        color: rgba(255,255,255,.75);
        text-align: center;
    }

    /**/
    .portfolio-tabs-container {
        width: 100%;
        background: linear-gradient( 90deg, rgba(88, 28, 135, .15), rgba(15, 23, 42, .30), rgba(6, 182, 212, .15) );

        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 24px;
        padding: 12px;
        overflow: hidden;
    }

        .portfolio-tabs-container .mud-tabs-tabbar {
            width: 100%;
        }

        .portfolio-tabs-container .mud-tabs-tabbar-inner,
        .portfolio-tabs-container .mud-tabs-tabbar-content,
        .portfolio-tabs-container .mud-tabs-tabbar-wrapper {
            width: 100%;
        }

        .portfolio-tabs-container .mud-tabs-tabbar-wrapper {
            display: flex;
            width: 100%;
            gap: 12px;
        }

        .portfolio-tabs-container .d-inline-block {
            flex: 1;
            width: auto !important;
        }

        .portfolio-tabs-container .mud-tab-slider {
            display: none !important;
        }

        .portfolio-tabs-container .mud-tab {
            min-width: 0 !important;
            max-width: none !important;
            width: 100%;
            color: rgba(255,255,255,.65);
            transition: all .3s ease;
            border-radius: 16px;
        }
        .portfolio-tabs-container .mud-tab {
            transition: all .3s ease;
            min-height: 70px;
        }

            .portfolio-tabs-container .mud-tab:hover {
              /*   transform: translateY(-4px); */
                background: rgba(255,255,255,.05);
                color: white;
                border-radius: 16px;
                border: 1px solid var(--portfolio-tabs-container-shadow);
            }

            .portfolio-tabs-container .mud-tab.mud-tab-active .mud-icon-root {
                /* color: #a78bfa; */
                color: white;
            }

            .portfolio-tabs-container .mud-tab .mud-icon-root {
                transition: all .3s ease;
            }

            .portfolio-tabs-container .mud-tab:hover .mud-icon-root {
                transform: rotate(-12deg) scale(1.1);
                color: var(--portfolio-tabs-container-color);
                font-size: 1.5rem;
         /*        color: #a855f7; */
            }

            .portfolio-tabs-container .mud-tab .d-flex {
                padding: 10px 0;
            }

            /*                 background: linear-gradient( 135deg, rgba(99,102,241,.25), rgba(168,85,247,.15) ); */
            .portfolio-tabs-container .mud-tab.mud-tab-active {

                background: var(--portfolio-tabs-container-bgrgba);
                color: white !important;
                border: none !important;
                box-shadow: 0 0 20px rgba(99,102,241,.15);
            }

            .portfolio-tabs-container .mud-tab:hover {
                border: 1px solid var(--portfolio-tabs-container-shadow);
                border-radius: 16px;
                background: rgba(255,255,255,.04);
                color: white;
            }

            .portfolio-tabs-container .mud-icon-root {
                font-size: 1.5rem;
                margin-bottom: 8px;
            }

        .portfolio-tabs-container .mud-typography {
            font-weight: 600;
        }

    .mud-tabs-tabbar {
        position: relative;
        background-color: transparent;
    }



    .see-more-button {
        background: linear-gradient( 135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.90) );
        border: 1px solid rgba(255,255,255,.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }


        .see-more-button:hover, .see-more-button:focus-visible {
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.3);
    }


    /*Mobile*/
    .mobile-tabs{
        background: linear-gradient( 135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.90) );
        border: 1px solid rgba(255,255,255,.08);
        color: white !important;
        box-shadow: 0 0 20px rgba(99,102,241,.15);
        border-radius:8px;
    }

    .mobile-tabs-active{
        background: var(--portfolio-tabs-container-bgrgba);
        color: white !important;
        border: 1px solid var(--portfolio-tabs-container-shadow);
        box-shadow: 0 0 20px rgba(99,102,241,.15);
        border-radius: 8px;
    }


    @@media (prefers-reduced-motion: no-preference) {
        .see-more-button:hover, .see-more-button:focus-visible {
            transform: scale(1.1);
        }
    }
</style>

@code
{
    private bool _isMobile;
    int activeIndex = 0;
    protected override void OnInitialized()
    {
        GradientService.OnChange += Refresh;
    }
    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private Task BreakpointChanged(Breakpoint breakpoint)
    {
        _isMobile = breakpoint <= Breakpoint.Sm;
        StateHasChanged();
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        GradientService.OnChange -= Refresh;
    }
}