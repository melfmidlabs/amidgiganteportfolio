@implements IDisposable

<MudBreakpointProvider OnBreakpointChanged="BreakpointChanged" />
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="" >
    <MudStack AlignItems="AlignItems.Center">
        <MudStack data-aos="zoom-in-up"
             data-aos-duration="600">
            <MudText Typo="Typo.h2"
                     Align="Align.Center"
                     Class=@($"gradient-text-title mb-6") style="@($"--gradient-text-title-bg:{GradientService.CurrentTheme.Background}")">
                About Me
            </MudText>
        </MudStack>
 

        <MudText Typo="Typo.body1"
                 Align="Align.Center"
                 Class="about-description"
                 data-aos="fade-right"
                 data-aos-duration="1500">

            Hello, I'm

            <span class="highlight-name">
                Amid Gigante Jr.
            </span>

            passionate about building scalable web applications, embedded systems,
            and IoT solutions. I enjoy working with ASP.NET Core, Blazor, PostgreSQL,
            and ESP32-based projects.

            Focused on continuous learning and innovation, I strive to create
            efficient software that solves real-world problems and delivers
            meaningful user experiences.

        </MudText>

        <MudStack Class="mt-6" Row="@(_currentBreakpoint > Breakpoint.Sm)" Reverse="@_reverse">

            <MudButton Variant="Variant.Text"
                       Class="cv-button"
                       Style="@($"--cv-button-bg:{GradientService.CurrentTheme.Background}; --cv-button-shadow:{GradientService.CurrentTheme.Shadow};")"
                       Href="documents/AmidGiganteJr_Resume.pdf"
                       Target="_blank" data-aos="fade-up"
                       data-aos-duration="800">

                Download Resume

            </MudButton>

            <MudButton OnClick="@(() => Go("portfolio"))"
                       StartIcon="@Icons.Material.Filled.Code"
                       Variant="Variant.Outlined"
                       Class="projects-button"
                       Style="@($"--project-button-color:{GradientService.CurrentTheme.Color}; --project-button-shadow:{GradientService.CurrentTheme.Shadow};")"
                       data-aos="fade-up"
                       data-aos-duration="800">

                View Projects

            </MudButton>

        </MudStack>


        <MudGrid Class="mt-8">

            <MudItem xs="12" sm="4">
                <!--TOTAL PROJECTS-->
                <MudPaper Class="stats-card" Style="@($"--stats-card-shadow:{GradientService.CurrentTheme.ShadowRgba}")"
                          Elevation="0"
                          data-aos="fade-right"
                          data-aos-duration="1300">


                    <div class="stats-content">

                        <div class="stats-header">

                            <div class="stats-icon">

                                <MudIcon Icon="@Icons.Material.Outlined.Code"
                                         Size="Size.Large" />

                            </div>

                            <MudText Typo="Typo.h4"
                                     Class="stats-number"
                                     data-aos="fade-up-left"
                                     data-aos-duration="1500">
                                @totalProjects
                            </MudText>

                        </div>

                        <MudText Class="stats-title"
                                 data-aos="fade-up"
                                 data-aos-duration="800">
                            TOTAL PROJECTS
                        </MudText>

                        <div class="d-flex justify-space-between align-center">

                            <MudText Class="stats-description"
                                     data-aos="fade-up"
                                     data-aos-duration="1000">
                                Real-world web, IoT, and embedded systems projects successfully designed and developed.
                            </MudText>

                            <MudIcon Icon="@Icons.Material.Outlined.NorthEast"
                                     Class="stats-arrow" />

                        </div>

                    </div>

                </MudPaper>

            </MudItem>

            <MudItem xs="12" sm="4">
                <!--YEARS OF CODING-->
                <MudPaper Class="stats-card" Style="@($"--stats-card-shadow:{GradientService.CurrentTheme.ShadowRgba}")"
                          Elevation="0"
                          data-aos="fade-up"
                          data-aos-duration="1300">

                    

                    <div class="stats-content">

                        <div class="stats-header">

                            <div class="stats-icon">

                                <MudIcon Icon="@Icons.Material.Outlined.WorkOutline"
                                         Size="Size.Large" />

                            </div>

                            <MudText Typo="Typo.h4"
                                     Class="stats-number"
                                     data-aos="fade-up-left"
                                     data-aos-duration="1500">
                                @yearsOfCoding
                            </MudText>

                        </div>

                        <MudText Class="stats-title"
                                 data-aos="fade-up"
                                 data-aos-duration="800">
                            YEARS OF CODING
                        </MudText>

                        <div class="d-flex justify-space-between align-center">

                            <MudText Class="stats-description"
                                     data-aos="fade-up"
                                     data-aos-duration="1000">
                                Continuous learning and hands-on experience building modern software solutions.
                            </MudText>

                            <MudIcon Icon="@Icons.Material.Outlined.NorthEast"
                                     Class="stats-arrow" />

                        </div>

                    </div>

                </MudPaper>

            </MudItem>

            <MudItem xs="12" sm="4">
                <!--TECH STACK-->
                <MudPaper Class="stats-card" Style="@($"--stats-card-shadow:{GradientService.CurrentTheme.ShadowRgba}")"
                          Elevation="0"
                          data-aos="fade-left"
                          data-aos-duration="1300">

                    

                    <div class="stats-content">

                        <div class="stats-header">

                            <div class="stats-icon">

                                <MudIcon Icon="@Icons.Material.Outlined.Memory"
                                         Size="Size.Large" />

                            </div>

                            <MudText Typo="Typo.h4"
                                     Class="stats-number"
                                     data-aos="fade-up-left"
                                     data-aos-duration="1500">
                               @techStacks
                            </MudText>

                        </div>

                        <MudText Class="stats-title"
                                 data-aos="fade-up"
                                 data-aos-duration="800">
                            TECH STACK
                        </MudText>

                        <div class="d-flex justify-space-between align-center">

                            <MudText Class="stats-description"
                                     data-aos="fade-up"
                                     data-aos-duration="1000">
                                Proficient in web development, databases, cloud services, and embedded systems.
                            </MudText>

                            <MudIcon Icon="@Icons.Material.Outlined.NorthEast"
                                     Class="stats-arrow" />

                        </div>

                    </div>

                </MudPaper>

            </MudItem>

        </MudGrid>

    
    </MudStack>
   

</MudContainer>

