    /**/
    .project-card {
        position: relative;
        background: linear-gradient( 135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.90) );
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        padding: 1rem;
        overflow: hidden;
        transition: all .3s ease;
    }

        .project-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient( 135deg, rgba(99,102,241,.15), rgba(168,85,247,.15) );
            opacity: 0;
            transition: .3s;
        }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(99,102,241,.25);
        }

            .project-card:hover::before {
                opacity: 1;
            }

    .profile-avatar {
        width: 140px;
        height: 140px;
        margin: auto;
    }

    .about-description {
        max-width: 900px;
        margin: 0 auto;
        font-size: 1.15rem;
        line-height: 2rem;
        color: rgba(255,255,255,.75);
        text-align: center;
    }

    .highlight-name {
        font-weight: 700;
        color:#e3ddff;
    }

