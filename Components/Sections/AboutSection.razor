    .stats-content {
        position: relative;
        z-index: 2;
    }

    .stats-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .stats-icon {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        transition: transform .3s ease;
    }

    .stats-card:hover .stats-icon {
        transform: rotate(8deg);
    }

    .stats-number {
        font-family: 'DM Mono', monospace !important;
        font-weight: 700;
    }

    .stats-title {
        font-size: .85rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(255,255,255,.75);
        margin-bottom: .75rem;
    }

    .stats-description {
        font-size: .8rem;
        color: rgba(255,255,255,.55);
        max-width: 180px;
    }

    .stats-arrow {
        opacity: .5;
        transition: .3s ease;
    }

    .stats-card:hover .stats-arrow {
        opacity: 1;
    }

    /**/
    .cv-button {
        background: var(--cv-button-bg) !important;
        color: white !important;
        font-weight: 600;
        border-radius: 12px;
        padding: 12px 24px;
        transition: all .3s ease;
        box-shadow: 0 10px 25px var(--cv-button-shadow);
        animation: bounce-slow 3s infinite;
    }

        .cv-button:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 15px 35px color-mix(in srgb, var(--cv-button-shadow) 55%, transparent), 0 0 45px color-mix(in srgb, var(--cv-button-shadow) 35%, transparent), 0 0 70px color-mix(in srgb, var(--cv-button-shadow) 20%, transparent);
        }
    @@keyframes bounce-slow {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-5px);
        }
    }
    /**/
    .projects-button {
        color: var(--project-button-color) !important;
        border: 1px solid var(--project-button-color);
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all .3s ease;
        animation: bounce-slow 3s infinite;
        animation-delay: .2s;
    }


        .projects-button:hover {
            transform: translateY(-3px) scale(1.05);
            background: color-mix( in srgb, var(--project-button-color) 12%, transparent );
            border-color: var(--project-button-color) !important;
            box-shadow: 0 15px 35px color-mix(in srgb, var(--project-button-shadow) 55%, transparent), 0 0 45px color-mix(in srgb, var(--project-button-shadow) 35%, transparent), 0 0 70px color-mix(in srgb, var(--project-button-shadow) 20%, transparent);
        }



    @@media (max-width:768px) {
        .about-description {
            max-width: 900px;
            margin: 0 auto;
            font-size: 1rem;
            line-height: 2rem;
            color: rgba(255,255,255,.75);
            text-align: center;
        }
    }
</style>

@code {

    private Breakpoint _currentBreakpoint;
    private bool _row = false;
    private bool _reverse = false;
    private string totalProjects = "10+";
    private string yearsOfCoding = "3+";
    private string techStacks = "10+";

    protected override void OnInitialized()
    {
        GradientService.OnChange += Refresh;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task Go(string id)
    {
        await NavigationService.ScrollTo(id);
    }

    private Task BreakpointChanged(Breakpoint breakpoint)
{
    _currentBreakpoint = breakpoint;
    StateHasChanged();
    return Task.CompletedTask;
}

    public void Dispose()
    {
        GradientService.OnChange -= Refresh;
    }
}